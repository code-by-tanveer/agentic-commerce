# URL of the backend API. Used by:
#   1. Next.js rewrites to proxy /api/* (see `next.config.mjs`).
#   2. Server-side SSR fetch in `app/s/[id]/page.tsx` (the public lookbook
#      page bypasses the rewrite proxy and hits the backend directly so the
#      page works in Vercel preview / production environments where the
#      rewrite host is not the same machine as the FE).
#
# Required in production (Vercel/Fly deploy). In local `next dev` the default
# `http://localhost:4000` matches the backend's default port.
BACKEND_URL=http://localhost:4000
