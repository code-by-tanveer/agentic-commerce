# Public URL where your UCP agent profile JSON is hosted.
# Required by every Catalog MCP request.
UCP_PROFILE_URL=https://example.com/.well-known/ucp-profile.json

# Catalog MCP endpoint (override only for staging/test mirrors).
CATALOG_MCP_URL=https://catalog.shopify.com/api/ucp/mcp

# OPTIONAL — JWT client-credentials, if your Catalog MCP deployment requires them.
# Leave blank to send unauthenticated requests.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_TOKEN_URL=

# Groq Cloud (LLM provider, see docs/adr/0001-llm-provider-groq.md).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# SQLite database file path (see docs/adr/0004-session-store-sqlite.md).
DB_PATH=data/agentic.db

# Uploads (Cycle 4 vision flow). Created on first use.
UPLOAD_DIR=data/uploads
# Hours before a stored upload is auto-purged (ARCH §9). Default 24.
UPLOAD_TTL_HOURS=24
# Defensive cap on Groq vision response tokens. Bounds vision spend.
VISION_MAX_INPUT_TOKENS=4096

# Hex/string salt used to hash client IPs for sessions.ip_hash.
# Set this in production. Dev will auto-generate one with a warning.
IP_HASH_SALT=

# Backend HTTP server.
PORT=4000

# CORS — comma-separated origins allowed to call this backend.
ALLOWED_ORIGINS=http://localhost:3000
